layout {

    focus-ring {
        active-color   "#b7c8de"
        inactive-color "#131315"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#b7c8de"
        inactive-color "#131315"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#b7c8de"
        inactive-color "#314153"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#b7c8de80"
    }
}

recent-windows {
    highlight {
        active-color "#b7c8de"
        urgent-color "#ffb4ab"
    }
}
